# Data files (large, don't commit to GitHub)
data/
!data/.gitkeep

# Results (can commit final summaries, not raw data)
results/**/*.json
results/**/raw/
validation/*.json
!validation/.gitkeep

# Container images and caches
*.tar
*.tar.gz
containers/cache/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Julia
Manifest.toml
*.jl.cov
*.jl.*.cov
*.jl.mem
deps/deps.jl

# R
.Rhistory
.RData
.Rproj.user
*.Rproj

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
*.bak

# Temporary files
tmp/
temp/
*.log

# Keep these directories but ignore contents
!results/.gitkeep
!results/reports/
!results/figures/
results/reports/*.md
results/figures/*.png
results/figures/*.pdf

# Allow documentation and final outputs
!README.md
!*.md
!IMPROVEMENTS.md
!STATISTICAL_FEATURES.md
